# Copy to .env and fill in values. Viper also reads these from the environment (e.g. on Vercel).
# See VERCEL.md for Vercel deployment.

# Server
SERVER_HOST=localhost
SERVER_PORT=8080

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=go_kit_base
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_SSL_MODE=disable

# App
APP_ENVIRONMENT=development
APP_LOG_LEVEL=info
APP_DEBUG=false
# APP_DAILY_LOG_UPLOAD_PATH=./data/uploads/daily-log

# Auth — required; must not be empty in production
AUTHENTICATION_JWT_SECRET=change-me
AUTHENTICATION_JWT_EXPIRY=24h
